# Copy to .env (or set in your shell) to override defaults.

# Port the HTTP server listens on. Default: 8080.
PORT=8080

# Data file path (a plain JSON file; created if it doesn't exist).
DB_PATH=./shortener.db

# Public base URL used to build the `shortUrl` field in POST /shorten responses.
# In production, set this to the public-facing host (e.g., https://yourshort.ly).
BASE_URL=http://localhost:8080
